{
  "mcpServers": {
    "audiobookshelf-mcp": {
      "command": "uv",
      "args": [
        "run",
        "audiobookshelf-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "AUDIOBOOKSHELF_TOKEN": "your_token_here",
        "AUDIOBOOKSHELF_URL": "http://localhost:13378",
        "AUTHORSTOOL": "True",
        "EMAILTOOL": "True",
        "LIBRARIESTOOL": "True",
        "NOTIFICATIONTOOL": "True",
        "PODCASTSTOOL": "True",
        "SERIESTOOL": "True"
      }
    }
  }
}
